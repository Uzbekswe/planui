{
  "name": "@uzbekswe/planui",
  "version": "0.3.1",
  "description": "Structured review workflows for AI coding agents — Claude Code, Codex CLI, and any MCP-compatible assistant. Annotate, approve, and copy structured feedback on AI-generated plans.",
  "license": "MIT",
  "author": {
    "name": "Mukhammadali",
    "email": "uzbekswe@gmail.com",
    "url": "https://github.com/Uzbekswe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Uzbekswe/planui.git"
  },
  "homepage": "https://github.com/Uzbekswe/planui#readme",
  "bugs": {
    "url": "https://github.com/Uzbekswe/planui/issues"
  },
  "funding": "https://github.com/sponsors/Uzbekswe",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "mcp",
    "model-context-protocol",
    "multi-assistant",
    "plan",
    "plan-mode",
    "planui",
    "ai-agent",
    "ai-review",
    "human-in-the-loop",
    "html-renderer",
    "mermaid",
    "annotation"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "mcpName": "io.github.Uzbekswe/planui",
  "bin": {
    "planui": "dist/cli.js",
    "planui-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/template dist/template && chmod 755 dist/cli.js dist/server.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "marked": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
